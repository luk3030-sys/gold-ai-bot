# Core
SYMBOL=XAU/USD
TWELVEDATA_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TIMEZONE=Europe/Warsaw

# Persistent data layer (recommended)
# Paste PostgreSQL connection URL from your DB provider / Render Postgres.
DATABASE_URL=
# SQLite fallback only. Avoid /tmp if you need persistence.
# DATABASE_PATH=/var/data/gold_ai_bot_v5_1.db

# Signal quality
MIN_SCORE=80
MIN_RR=2.0
USE_CLOSED_CANDLES=true
MAX_SIGNALS_PER_DAY=3
SIGNAL_COOLDOWN_MINUTES=60
LOSS_COOLDOWN_MINUTES=120
PRIMARY_TARGET=TP2
MAX_SIGNAL_AGE_HOURS=72
AMBIGUOUS_POLICY=conservative
TRACK_INTERVAL=15min
VALIDATION_MIN_SCORE=80

# Automation
# Recommended false when cron-job.org calls /tick every 5 minutes.
SCHEDULER_ENABLED=false
ANALYZE_INTERVAL_MINUTES=5
DAILY_REPORT_HOUR=7
CRON_SECRET=
TICK_LOCK_TTL_SECONDS=240

# Data resilience
API_CACHE_SECONDS=45
API_STALE_CACHE_SECONDS=900
USE_STALE_CACHE_ON_ERROR=true
HTTP_RETRIES=3
HTTP_TIMEOUT_SECONDS=25
READY_CHECK_MARKET=true

# DXY / USD context
DXY_ENABLED=true
DXY_SYMBOLS=DXY,DX
# Optional explicit proxy. It is marked as PROXY and gets a smaller score weight.
DXY_PROXY_SYMBOL=
DXY_REQUIRED=false
DXY_WEIGHT=5
DXY_PROXY_WEIGHT=2
DXY_MISSING_PENALTY=5
DXY_FAILURE_CACHE_SECONDS=900

# Runtime
PYTHON_VERSION=3.12.11

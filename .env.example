TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWELVEDATA_API_KEY=
SYMBOL=XAU/USD
DXY_SYMBOL=DXY
TIMEZONE=Europe/Warsaw

# Live strategy
MIN_SCORE=80
MIN_RR=2.0
USE_CLOSED_CANDLES=true
LEVEL_LOOKBACK=40
DXY_MISSING_PENALTY=5
MACRO_BLOCK=false

# Automation
SCHEDULER_ENABLED=true
ANALYZE_INTERVAL_MINUTES=5
DAILY_REPORT_HOUR=7
CRON_SECRET=

# Signal controls
MAX_SIGNALS_PER_DAY=3
SIGNAL_COOLDOWN_MINUTES=60
LOSS_COOLDOWN_MINUTES=120
PRIMARY_TARGET=TP2
MAX_SIGNAL_AGE_HOURS=72
AMBIGUOUS_POLICY=conservative
TRACK_INTERVAL=15min
TRACK_OUTPUTSIZE=500

# Performance database
# On Render Free /tmp is ephemeral. For paid persistent disk set e.g. /var/data/gold_ai_bot_v5.db
DATABASE_PATH=/tmp/gold_ai_bot_v5/gold_ai_bot_v5.db

# Validation
VALIDATION_MIN_SCORE=80
VALIDATION_MAX_HOLD_H1_BARS=72
API_CACHE_SECONDS=45

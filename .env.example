# Core
SYMBOL=XAU/USD
TWELVEDATA_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TIMEZONE=Europe/Warsaw

# Persistent PostgreSQL — strongly recommended
DATABASE_URL=
# SQLite fallback only
# DATABASE_PATH=/var/data/gold_ai_bot_v6_3.db

# Signal quality
MIN_SCORE=80
MIN_RR=2.0
USE_CLOSED_CANDLES=true
MAX_SIGNALS_PER_DAY=3
SIGNAL_COOLDOWN_MINUTES=60
LOSS_COOLDOWN_MINUTES=120
PRIMARY_TARGET=TP2
MAX_SIGNAL_AGE_HOURS=72
AMBIGUOUS_POLICY=conservative
TRACK_INTERVAL=15min
VALIDATION_MIN_SCORE=80
ENTRY_ZONE_MIN_POINTS=2.0

# Institutional Smart Money weights
SMC_WEIGHT_M15=0.30
SMC_WEIGHT_H1=0.55
SMC_WEIGHT_H4=0.75

# Automation
# Recommended false when external cron calls /tick.
SCHEDULER_ENABLED=false
ANALYZE_INTERVAL_MINUTES=5
DAILY_REPORT_HOUR=7
CRON_SECRET=
TICK_LOCK_TTL_SECONDS=240

# Large candle / fast move alerts
MOVE_ALERT_ENABLED=true
MOVE_ALERT_INTERVAL=15min
MOVE_ALERT_OUTPUTSIZE=120
MOVE_ALERT_ATR_MULT=0.90
MOVE_ALERT_RANGE_ATR_MULT=1.20
MOVE_ALERT_BODY_RATIO_MIN=0.55
MOVE_ALERT_MIN_ABS_MOVE=0.0

# Data resilience
API_CACHE_SECONDS=45
API_STALE_CACHE_SECONDS=900
USE_STALE_CACHE_ON_ERROR=true
HTTP_RETRIES=3
HTTP_TIMEOUT_SECONDS=25
READY_CHECK_MARKET=true

# DXY / USD context
DXY_ENABLED=true
DXY_SYMBOLS=DXY,DX
DXY_PROXY_SYMBOL=
DXY_REQUIRED=false
DXY_WEIGHT=5
DXY_PROXY_WEIGHT=2
DXY_MISSING_PENALTY=5
DXY_FAILURE_CACHE_SECONDS=900

# Manual macro kill switch
MACRO_BLOCK=false

# Runtime
PYTHON_VERSION=3.12.11
